{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "types": ["node", "electron"],
    "baseUrl": ".",
    "outDir": "dist-tsc"
  },
  "include": ["src/**/*.ts", "tests/**/*.ts", "electron.vite.config.ts"]
}
